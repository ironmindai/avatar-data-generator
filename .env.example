# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=avatar_data_generator
DB_USER=avatar_data_gen
DB_PASSWORD=your_secure_password_here

# Application Configuration
APP_PORT=8085
FLASK_ENV=production
SECRET_KEY=your_secret_key_here

# Optional: Direct connection string format
DATABASE_URL=postgresql://avatar_data_gen:your_secure_password_here@localhost:5432/avatar_data_generator

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Flowise Configuration
MULTITHREAD_FLOWISE=5

# Worker Configuration
WORKER_INTERVAL=5
# Optional: Sleep interval between task checks (in seconds) - for standalone worker mode only
WORKER_SLEEP_INTERVAL=30
# Concurrent persona processing limit (OpenAI Tier 3: 50 images/min for gpt-image-1)
# Safe limit: 10-20 concurrent personas (each generates 1 base image)
CONCURRENT_PERSONA_LIMIT=15

# S3 Storage Configuration (MinIO)
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=your_s3_access_key_here
S3_SECRET_KEY=your_s3_secret_key_here
S3_REGION=us-east-1
S3_BUCKET_NAME=avatar-images
S3_IMAGE_DATASETS_BUCKET=image-datasets
# Public URL base for accessing S3 objects (e.g., https://s3-api.dev.iron-mind.ai)
S3_PUBLIC_URL_BASE=https://s3-api.dev.iron-mind.ai

# Image Generation Configuration
# Optional text to append to all image generation prompts (base and actual)
# Leave empty for no appending. Example: "no text on the generated image please"
BASE_PROMPT_APPEND=

# ═══════════════════════════════════════════════════════════════════════
# LEGACY/DEPRECATED CONFIGURATION (not used with OpenRouter)
# ═══════════════════════════════════════════════════════════════════════

# BytePlus API (SeeDream) - DEPRECATED: replaced by OpenRouter Nano Banana 2
# BYTEPLUS_API="your_byteplus_api_key_here"

# Two-Stage Avatar Generation Pipeline - DEPRECATED: replaced by OpenRouter
# Set to True to enable RunPod Stage 1 + OpenAI Stage 2 pipeline
# Set to False to use legacy single-stage OpenAI pipeline
# USE_TWO_STAGE_PIPELINE=False

# Save intermediate images from RunPod Stage 1 for debugging (optional)
# SAVE_INTERMEDIATE_IMAGES=False

# RunPod Configuration (ComfyUI Endpoint) - DEPRECATED: replaced by OpenRouter
# RUNPOD_API_KEY=your_runpod_api_key_here
# RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id_here
# RUNPOD_TIMEOUT=2400
# RUNPOD_POLL_INTERVAL=10

# RunPod Optimized Parameters (from testing - see docs/runpod-base-image-generation.md)
# RUNPOD_DENOISE=0.47
# RUNPOD_IP_WEIGHT=0.75
# RUNPOD_GUIDANCE_SCALE=7.5
# RUNPOD_STEPS=30

# OpenRouter API Configuration (RECOMMENDED - replaces OpenAI for image generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Base image generation model (Nano Banana 2 / Gemini 3.1 Flash Image Preview)
OPENROUTER_MODEL=openai/gpt-5-image
# Enable OpenRouter for base image generation (set to True to use OpenRouter instead of OpenAI)
USE_OPENROUTER=True

# OpenRouter Scene Generation Configuration
# Enable OpenRouter for scene-based image generation (replaces SeeDream/BytePlus)
USE_OPENROUTER_SCENE=True
# Scene generation model (Nano Banana 2 / Gemini 3.1 Flash Image Preview)
OPENROUTER_SCENE_MODEL=google/gemini-3.1-flash-image-preview

# ═══════════════════════════════════════════════════════════════════════
# NANO BANANA 2 (Gemini 3.1 Flash Image Preview) CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# Base Image Prompt Strategy
# Controls how the base selfie image is generated from reference face
# Options: 'original', 'transform_explicit' (RECOMMENDED), 'convert_preserve',
#          'remake_nuclear', 'recreate_balanced', 'two_step', 'negative_positive',
#          'authentic_repeat', 'percentage', 'as_if'
# transform_explicit = Strong ethnic/demographic override (best for diverse datasets)
# convert_preserve = Explicit instructions with feature preservation
# See docs/nano-banana-prompt-optimization.md for details
NANO_BANANA_PROMPT_STRATEGY=transform_explicit

# Temperature (Gemini 3.1 Flash Image Preview)
# Default: 1.0 (Gemini 3 optimized - RECOMMENDED)
# WARNING: Values < 1.0 may cause degraded performance/looping per Google Gemini 3 docs
# Range: 0.0 (deterministic) to 2.0 (maximum creativity)
# Lower values = stronger prompt adherence, but may degrade Gemini 3 performance
NANO_BANANA_TEMPERATURE=1.0

# Expression Normalization (prevents closed eyes, shouting, extreme expressions from seed)
# Set to True to neutralize expressions from random S3 seed images
NANO_BANANA_NORMALIZE_EXPRESSION=True

# Expression Style (what expression to generate instead)
# Options: 'neutral_natural' (RECOMMENDED), 'slight_smile', 'relaxed', 'candid', 'friendly'
# neutral_natural = Open eyes, neutral face, natural slight smile, calm demeanor
# slight_smile = Open eyes, friendly warm smile
# relaxed = Open eyes, completely neutral, no tension
# candid = Open eyes, natural candid moment (not posed)
# friendly = Open eyes, gentle smile, warm and approachable
NANO_BANANA_EXPRESSION_STYLE=neutral_natural

# Base Image Attire Control (prevents wrong-gender clothing from reference)
# Set to True to add gender-appropriate attire instruction to base image prompt
# Example: Male reference in dress → generates male in casual male attire
NANO_BANANA_BASE_ATTIRE_CONTROL=True

# Scene-Based Image Generation Prompt Strategy
# Controls how the person is integrated into scene images (prevents cheap cutout effect)
# Options: 'original', 'natural_blend' (RECOMMENDED), 'photorealistic_integration',
#          'seamless_replace', 'blend_adaptive', 'environment_aware'
# natural_blend = Natural integration, lighting match, gender-appropriate attire, no cutout
# photorealistic_integration = Maximum realism, environmental awareness, perfect lighting
# seamless_replace = Seamless replacement with gender attire correction
# blend_adaptive = Adaptive blending with explicit gender clothing rules
# environment_aware = Context-aware integration with lighting analysis
# See docs/nano-banana-prompt-optimization.md for details
NANO_BANANA_SCENE_PROMPT_STRATEGY=natural_blend

# ═══════════════════════════════════════════════════════════════════════
# BASE IMAGE FACE SOURCE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# Base Image Face Source Configuration
# Controls where random face images come from for base image generation
# Options: 's3_faces' (default) or 'image_datasets'
# s3_faces = Use dedicated faces bucket with male/female folders (supports gender filtering)
# image_datasets = Use selected image datasets as face source (no gender filtering)
BASE_IMAGE_FACE_SOURCE=s3_faces

# Base Image Dataset IDs (required when BASE_IMAGE_FACE_SOURCE='image_datasets')
# Comma-separated list of dataset identifiers to use as face sources
# Supports BOTH formats (system auto-detects):
#   - Integer IDs (table 'id' column): 1,2,3 or 19
#   - UUID dataset_ids (table 'dataset_id' column): 6ccdef5a-ceb9-4412-b3b8-4bbe37df703d
# Example: 1,2,3 (will randomly select from datasets 1, 2, and 3)
# NOTE: Gender filtering does NOT work with image_datasets (datasets don't have gender metadata)
# Leave empty when using s3_faces
BASE_IMAGE_DATASET_IDS=

# ═══════════════════════════════════════════════════════════════════════
# LEGACY SEEDREAM CONFIGURATION (not used with OpenRouter)
# ═══════════════════════════════════════════════════════════════════════

# SeeDream API Configuration (legacy - replaced by OpenRouter)
SEEDREAM_API_URL=https://ark.ap-southeast.bytepluses.com/api/v3/images/generations
SEEDREAM_MODEL=seedream-4-5-251128
SEEDREAM_IMAGE_SIZE=2560x1440
SEEDREAM_WATERMARK=false
